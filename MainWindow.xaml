<Window x:Class="MiniCursorAgent.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
        mc:Ignorable="d"
        Title="Mini Cursor Agent - .NET AI 编程助手"
        Width="1280" Height="780"
        MinWidth="1000" MinHeight="640"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <ToolBar DockPanel.Dock="Top" Padding="6">
            <Button x:Name="OpenButton" Content="打开 C# 文件" Padding="10,4" Margin="0,0,6,0" Click="OpenButton_Click" />
            <Button x:Name="SaveButton" Content="保存当前文件" Padding="10,4" Margin="0,0,6,0" Click="SaveButton_Click" IsEnabled="False" />
            <Button x:Name="ReloadButton" Content="重新加载" Padding="10,4" Margin="0,0,6,0" Click="ReloadButton_Click" IsEnabled="False" />
            <Separator />
            <CheckBox x:Name="AutoWriteCheckBox" Content="允许 Agent 写入文件（会自动备份）" Margin="8,0,8,0" VerticalAlignment="Center" IsChecked="True" />
            <Separator />
            <TextBlock Text="当前文件：" VerticalAlignment="Center" Margin="8,0,4,0" />
            <TextBlock x:Name="CurrentFileTextBlock" Text="未打开" VerticalAlignment="Center" FontWeight="SemiBold" />
        </ToolBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="1.15*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#F3F4F6" Padding="10,6" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
                    <TextBlock Text="代码编辑区" FontWeight="Bold" />
                </Border>
                <avalon:TextEditor x:Name="CodeEditor"
                                   Grid.Row="1"
                                   FontFamily="Consolas"
                                   FontSize="14"
                                   ShowLineNumbers="True"
                                   SyntaxHighlighting="C#"
                                   WordWrap="False"
                                   HorizontalScrollBarVisibility="Auto"
                                   VerticalScrollBarVisibility="Auto" />
            </Grid>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#E5E7EB" />

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#F3F4F6" Padding="10,6" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="AI Agent 面板" FontWeight="Bold" />
                        <TextBlock Text="  |  会显示 Thought / Action / Observation" Foreground="#555555" />
                    </StackPanel>
                </Border>

                <RichTextBox x:Name="AgentLogTextBox"
                             Grid.Row="1"
                             FontFamily="Consolas"
                             FontSize="13"
                             VerticalScrollBarVisibility="Auto"
                             IsReadOnly="True"
                             Padding="10"
                             Background="#FAFAFA"
                             BorderThickness="0">
                    <RichTextBox.Resources>
                        <Style TargetType="Paragraph">
                            <Setter Property="Margin" Value="0,1,0,2"/>
                        </Style>
                    </RichTextBox.Resources>
                </RichTextBox>

                <Border Grid.Row="2" BorderBrush="#DDDDDD" BorderThickness="0,1,0,0" Padding="8" Background="#FAFAFA">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBox x:Name="UserInputTextBox"
                                 Grid.Row="0"
                                 MinHeight="72"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Padding="8"
                                 Text="帮我审查当前文件，并指出可以改进的地方" />
                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                            <Button x:Name="ClearLogButton" Content="清空日志" Padding="12,5" Margin="0,0,8,0" Click="ClearLogButton_Click" />
                            <Button x:Name="SendButton" Content="发送给 Agent" Padding="16,5" Click="SendButton_Click" IsDefault="True" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
